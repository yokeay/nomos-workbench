# NOMOS AI Workbench - Environment Configuration Template
# 复制此文件为 .env.development/.env.staging/.env.production 并修改相应配置

# ==================== 业务前缀配置 ====================
# 业务前缀：用于区分不同业务的数据库表和Redis键
# 开发环境: nomos_dev_
# 预发布: nomos_stg_
# 生产环境: nomos_prod_
BUSINESS_PREFIX=nomos_dev_

# ==================== 版本配置 ====================
VERSION_MAJOR=1
VERSION_MINOR=0
VERSION_PATCH=0

# ==================== 环境标识 ====================
ENVIRONMENT=development

# ==================== 数据库配置 ====================
# 开发环境使用SQLite本地文件
DATABASE_URL=file:./data/workbench.db
# 生产环境使用PostgreSQL连接字符串
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ==================== 服务器配置 ====================
PORT=5000
NEXTAUTH_URL=http://localhost:5000
NODE_ENV=development

# ==================== 认证配置 ====================
# 32字节hex = 64字符，生产环境务必修改此密钥！
NEXTAUTH_SECRET=development-secret-change-in-production
NEXTAUTH_URL=http://localhost:5000

# ==================== 加密配置 ====================
# 32字节hex = 64字符，用于TOTP密钥等敏感信息加密
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ==================== Terminal WebSocket URL ====================
NEXT_PUBLIC_TERMINAL_WS_URL=ws://localhost:8080

# ==================== AI模型配置 ====================
OLLAMA_BASE_URL=http://localhost:11434

# ==================== 安全备份配置 ====================
# 是否启用数据库定时备份（默认关闭）
ENABLE_BACKUP=false
# 备份存储目录
BACKUP_DIR=./data/backups

# ==================== 日志配置 ====================
# 可选: debug, info, warn, error
LOG_LEVEL=debug
